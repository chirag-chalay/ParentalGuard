<?xml version="1.0" encoding="utf-8"?>
<!--
  ============================================================
  AndroidManifest.xml
  Every Android app MUST have this file.
  It acts as the "table of contents" for your app — telling
  the Android OS:
    1. What permissions the app needs
    2. What components (Activities, Services, Receivers) exist
    3. How the app should behave at the system level

  The OS reads this file when installing and launching the app.
  ============================================================
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.parentalguard">

    <!-- ======================================================
         PERMISSIONS
         The app must declare every system resource it needs.
         Android will show these to the user at install time
         or ask at runtime (for "dangerous" permissions).
         ====================================================== -->

    <!-- LOCATION PERMISSIONS
         ACCESS_FINE_LOCATION   = precise GPS coordinates (required)
         ACCESS_COARSE_LOCATION = approximate location from cell/Wi-Fi
         ACCESS_BACKGROUND_LOCATION = keep getting location when app
                                      is not in the foreground.
                                      Android 10+ requires this separately. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- CALL LOG PERMISSIONS
         READ_CALL_LOG   = read the list of incoming/outgoing/missed calls
         READ_CONTACTS   = resolve phone numbers to contact names
         READ_PHONE_STATE = detect call state changes (ringing, active, idle) -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- NETWORK PERMISSIONS
         INTERNET             = send data to Firebase over the internet
         ACCESS_NETWORK_STATE = check if the device is online before syncing -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- BACKGROUND / BOOT PERMISSIONS
         RECEIVE_BOOT_COMPLETED = start our services automatically after reboot
         FOREGROUND_SERVICE     = run a persistent background service (required API 28+)
         FOREGROUND_SERVICE_LOCATION = specific foreground type for location (API 34+)
         REQUEST_IGNORE_BATTERY_OPTIMIZATIONS = ask user to exclude app from battery saver -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- SCREEN TIME (Usage Stats)
         PACKAGE_USAGE_STATS = read which apps are used and for how long.
         This is a "special" permission — it cannot be granted at runtime.
         The user must manually enable it in Settings > Digital Wellbeing.
         "tools:ignore" suppresses the IDE warning about it being protected. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- WAKE_LOCK = prevent the CPU from sleeping while our service runs,
         ensuring we never miss a location update -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ======================================================
         APPLICATION BLOCK
         Defines global app settings and lists all components.
         ====================================================== -->
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ParentalGuard">

        <!-- ================================================
             ACTIVITY: MainActivity
             The one screen that shows on first launch.
             Its only job is to request permissions and then
             start the background services — after which it
             closes itself so it stays hidden.
             ================================================ -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <!-- MAIN + LAUNCHER means this is the entry point
                 when the user taps the app icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ================================================
             SERVICE: LocationTrackingService
             Runs in the background as a Foreground Service.
             Sends the phone's GPS coordinates to Firebase
             every 5 minutes, even when the screen is off.

             foregroundServiceType="location" is REQUIRED on
             Android 10+ for any service that accesses location
             in the background. Without it the app crashes.
             ================================================ -->
        <service
            android:name=".services.LocationTrackingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- ================================================
             SERVICE: CallLogSyncService
             Runs in the background.
             Every 5 minutes it reads the device call log
             and app usage stats, then sends them to Firebase.

             foregroundServiceType="dataSync" marks it as a
             data synchronization service (Android 14+).
             ================================================ -->
        <service
            android:name=".services.CallLogSyncService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ================================================
             BROADCAST RECEIVER: BootReceiver
             Android calls this component automatically when
             the phone finishes booting up.

             Without this, our services would stop permanently
             every time the phone restarts. This makes them
             restart automatically after each reboot.

             exported="true" is required — the OS (outside our
             app) needs to be able to send this broadcast.
             ================================================ -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <!-- Standard boot complete event -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Some Samsung/Huawei devices use this event instead -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
