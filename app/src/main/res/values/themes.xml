<!--
  ============================================================
  res/values/themes.xml
  Defines the visual theme (colors, styles) for the app.

  Since MainActivity closes itself immediately after starting
  services, the theme is almost never visible to the user.
  We still need it to avoid a crash at launch.

  NoActionBar = hides the title bar, making the brief flash
  of the activity less noticeable.
  ============================================================
-->
<resources>
    <!-- Parent theme from AndroidX — supports both light and dark mode -->
    <style name="Theme.ParentalGuard" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary color — used for action bars, buttons, etc. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>

        <!-- Make the activity background match the window background
             to reduce the "flash" when the activity briefly appears -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
